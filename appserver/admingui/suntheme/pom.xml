<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.glassfish.main.admingui</groupId>
        <artifactId>admingui</artifactId>
        <version>8.0.3-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <!-- Coordinates are kept under org.glassfish.woodstock so that the runtime
         theme contract (jar layout under com/sun/webui/jsf/suntheme and the
         X-SJWUIC-Theme-* manifest headers) and existing consumers stay unchanged.
         The module was moved here from the glassfish-woodstock repository
         (see https://github.com/eclipse-ee4j/glassfish/issues/24495). -->
    <groupId>org.glassfish.woodstock</groupId>
    <artifactId>woodstock-webui-jsf-suntheme</artifactId>
    <packaging>jar</packaging>

    <name>Woodstock WebUI Jakarta Faces Suntheme</name>
    <description>Sun theme resources for the GlassFish Admin Console</description>

    <developers>
        <!-- See parent POM -->
    </developers>

    <properties>
        <timestamp>${maven.build.timestamp}</timestamp>
    </properties>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <includes>
                    <include>META-INF/*</include>
                </includes>
                <filtering>true</filtering>
            </resource>
            <resource>
                <directory>src/main/resources</directory>
                <targetPath>com/sun/webui/jsf/suntheme</targetPath>
                <excludes>
                    <exclude>META-INF/*</exclude>
                </excludes>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <manifestFile>${project.build.outputDirectory}/META-INF/MANIFEST.MF</manifestFile>
                    </archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
