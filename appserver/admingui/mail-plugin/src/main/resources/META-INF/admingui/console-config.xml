<console-config id="jmail">
    <integration-point
        id="jakartaMailResourceLink"
        parentId="propSheetSection"
        type="org.glassfish.admingui:resources"
        priority="100"
        content="jakartaMailResourceLink.jsf"
    />
    <integration-point
        id="jakartaMailNodes"
        type="org.glassfish.admingui:navNode"
        priority="500"
        parentId="resources"
        content="jakartaMailTreeNode.jsf"
    />
    <!-- add dropdown option for the resource dropdown of cluster/standalone instance resource table. -->
    <integration-point
            id="jakartaMailResourceDropDown"
            type="org.glassfish.admingui:resourceTypeDropdown"
            priority="500"
            content="jmail/mailResourceNew.jsf|org.glassfish.jmail.admingui.Strings|tree.javaMailSessions"
    />
    <integration-point
            id="jakartaMailFilter"
            type="org.glassfish.admingui:resFilterDropdown"
            priority="500"
            content="mail-resource|org.glassfish.jmail.admingui.Strings|tree.javaMailSessions"
    />
</console-config>
